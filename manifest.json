{
  "manifest_version": 3,
  "name": "YT Transcript Pro",
  "version": "1.0.0",
  "description": "Copy YouTube video transcripts as plain text or Markdown. Supports light and dark mode.",
  "permissions": ["storage", "clipboardWrite"],
  "host_permissions": ["*://*.youtube.com/*"],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "yt-transcript-pro@leopoldmac"
    }
  }
}
